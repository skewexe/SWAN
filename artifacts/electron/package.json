{
  "name": "@workspace/electron",
  "version": "1.0.0",
  "description": "Swan GMAO — Application bureau (Windows, Linux, macOS)",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev": "electron src/main.js",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --linux"
  },
  "dependencies": {
    "axios": "^1",
    "better-sqlite3": "^11.0.0",
    "express": "^4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.swan.gmao",
    "productName": "Swan GMAO",
    "copyright": "Copyright © 2026 Swan GMAO — MIT License",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../api-server",
        "to": "api-server",
        "filter": ["**/*", "!node_modules/**/*", "!dist/**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Swan GMAO",
      "license": "LICENSE.txt"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    }
  }
}
